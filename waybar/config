{
    "layer": "top",
        "position": "top",
        "reload_style_on_change": true,
        "modules-left": [
            "clock",
            "tray"
        ],
        "modules-center": [
            "sway/mode",
            "sway/workspaces"
            // "hyprland/workspaces"
        ],
        "modules-right": [
            "group/right_bubble",
            "battery",
        ],
        "hyprland/workspaces": {
            "format": "{icon}",
            "format-icons": {
                "active": "",
                "default": "",
                "empty": "",
                "persistent": ""
            },
        },
        "sway/workspaces": {
            "persistent-workspaces": {
                "1": [], "2": [], "3": [], "4": [], "5": []
            },
            "disable-scroll": true,
            "all-outputs": true,
            "format": "{icon}",
            "format-icons": {
                "urgent": "",
                "focused": "",
                "default": "",
            }
        },
        "clock": {
            "format": "{:%a %b %d %I:%M:%S %p} ",
            "interval": 1,   
            "timezone": "America/Los_Angeles",
            "tooltip-format": "<tt>{calendar}</tt>",
            "calendar": {
                "format": {
                    "months": "<span color='#000000'><b>{}</b></span>",
                    "weekdays": "<span color='#000000'><b>{}</b></span>",
                    "today": "<span color='#000000'><b>{}</b></span>"
                }
            },
            "actions": {
                "on-click-right": "shift_down",
                "on-click": "shift_up"
            }
        },
        "custom/dnd": {
            "format": "{}",
            "interval": 10,
            "exec": "if makoctl mode | grep -q 'dnd'; then echo ''; fi",
            "on-click": "sd dnd",
        },
        "custom/spotify": {
            "format": "{}",
            "interval": 5,
            "exec": "~/.config/waybar/music.sh",
            "on-click": "playerctl -p spotify play-pause; pkill -RTMIN+8 waybar",
            "on-scroll-up": "playerctl -p spotify next; pkill -RTMIN+8 waybar",
            "on-scroll-down": "playerctl -p spotify previous; pkill -RTMIN+8 waybar",
            "signal": 8,
        },
        "network": {
            "format-wifi": "",
            "format-ethernet":"",
            "format-disconnected": "",
            "tooltip-format-disconnected": "Error",
            "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
            "tooltip-format-ethernet": "{ifname} 🖧 ",
            "on-click": "kitty nmtui"
        },
        "power-profiles-daemon": {
          "format": "{icon}",
          "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
          "tooltip": true,
          "format-icons": {
            "default": "",
            "performance": "",
            "balanced": "",
            "power-saver": ""
          }
        },
        "bluetooth": {
            "format-on": "󰂯",
            "format-off": "BT-off",
            "format-disabled": "󰂲",
            "format-connected": "{num_connections} 󰂯",
            "format-connected-battery": "{device_battery_percentage}% 󰂯",
            "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
            "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
            "tooltip-format-enumerate-connected": "{device_alias}\n{device_address}",
            "tooltip-format-enumerate-connected-battery": "{device_alias}\n{device_address}\n{device_battery_percentage}%",
            "on-click": "rfkill toggle bluetooth",

            // Earphone Connection
            // "on-click-right": "blueman-manager"
            "on-click-right": "bluetoothctl connect 30:82:16:98:3B:D6",
        }, 
        "battery": {
            "interval": 60,
            "states": {
                "good": 80,
                "warning": 30,
                "critical": 20
            },
            "format": "{icon} {capacity}%",
            "format-charging": "󰂄 {capacity}%",
            "format-icons": [ "󰁻", "󰁼", "󰁾", "󰂀", "󰂂", "󰁹" ],
        },
        "custom/expand": {
            "format": "",
            "tooltip": false
        },
        "custom/endpoint":{
            "format": "|",
            "tooltip": false
        },
        "group/expand": {
            "orientation": "horizontal",
            "drawer": {
                "transition-duration": 600,
                "transition-to-left": true,
                "click-to-reveal": true
            },
            "modules": [
                "custom/expand",
                "cpu",
                "memory",
                "temperature",
                "custom/endpoint",
            ]
        },
        "group/right_bubble": {
            "orientation": "horizontal",
            "modules": [
                "group/expand",
                "custom/dnd",
                "custom/spotify",
                "bluetooth",
                "network",
                "power-profiles-daemon"
            ]
        },
        "cpu": {
            "format": "󰻠",
            "tooltip": true
        },
        "memory": {
            "format": ""
        },
        "temperature": {
            "critical-threshold": 80,
            "format": "{icon}",
            "format-icons": ["", "", ""]
        },
        "tray": {
            "icon-size": 14,
            "spacing": 10
        },
} 
